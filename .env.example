# ==============================================================================
# Sistema de Gestion de Tickets E-SEUS - Variables de Entorno
# ==============================================================================
# Copia este archivo como .env y configura los valores segun tu entorno.
#
#   Desarrollo:  cp .env.example .env
#   Produccion:  cp .env.example .env  (luego ajustar TODOS los valores)
#
# IMPORTANTE: Nunca subas el archivo .env al repositorio.
# ==============================================================================

# ------------------------------------------------------------------------------
# DJANGO CORE
# ------------------------------------------------------------------------------

# [OBLIGATORIO] Clave secreta de Django. En produccion debe ser una cadena
# aleatoria larga y unica. Genera una con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-CAMBIA-ESTO-EN-PRODUCCION-123456789

# Modo debug. En produccion SIEMPRE debe ser False.
# Valores validos: True | False
DEBUG=True

# [OBLIGATORIO en produccion] Hosts/dominios permitidos (separados por comas, sin espacios).
# Produccion ejemplo: e-seus.emtelco.com.co,10.0.0.50
# Desarrollo: localhost,127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1

# Modulo de settings de Django.
# Desarrollo:  config.settings.development
# Produccion:  config.settings.production
DJANGO_SETTINGS_MODULE=config.settings.development

# Sub-path del reverse proxy (sin slash final). Dejar vacio si Django esta en la raiz.
# Ejemplo: /e-learning/e-seus
FORCE_SCRIPT_NAME=

# ------------------------------------------------------------------------------
# BASE DE DATOS (MySQL)
# ------------------------------------------------------------------------------

# Nombre de la base de datos
DB_NAME=e-seus

# Usuario de la base de datos
DB_USER=root

# [OBLIGATORIO en produccion] Contrasena de la base de datos
DB_PASSWORD=

# Host del servidor MySQL.
# Produccion: IP del servidor o endpoint RDS (ej: db.example.com)
DB_HOST=localhost

# Puerto del servidor MySQL
DB_PORT=3306

# ------------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# ------------------------------------------------------------------------------

# Origenes permitidos para peticiones CORS (separados por comas, sin espacios).
# Produccion: la URL de tu frontend (ej: https://e-seus.emtelco.com.co)
# Desarrollo: http://localhost:3000,http://localhost:4200
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200,http://127.0.0.1:3000

# ------------------------------------------------------------------------------
# LOGGING
# ------------------------------------------------------------------------------

# Nivel de log de Django: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Desarrollo: INFO o DEBUG
# Produccion: WARNING o ERROR
DJANGO_LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# EMAIL (Solo necesario en produccion)
# ------------------------------------------------------------------------------

# Servidor SMTP
EMAIL_HOST=smtp.gmail.com

# Puerto SMTP (587 para TLS, 465 para SSL)
EMAIL_PORT=587

# Usar TLS: True | False
EMAIL_USE_TLS=True

# Usuario SMTP (correo electronico)
EMAIL_HOST_USER=

# Contrasena SMTP o App Password
EMAIL_HOST_PASSWORD=

# Direccion de remitente por defecto
DEFAULT_FROM_EMAIL=noreply@e-seus.com
